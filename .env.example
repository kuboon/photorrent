# Copy to `.env` for local dev (Deno reads these from the process env).
# All are optional locally: without them the app uses an in-memory manifest and
# STUN-only ICE (fine for same-network testing).

# --- Manifest persistence (Turso / libSQL) ---
# Without these, the manifest is kept in memory and lost on restart.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Cloudflare Realtime TURN (fallback relay for cross-NAT peers) ---
# Minted server-side; the token never reaches the browser. Without these,
# /api/ice returns STUN only.
TURN_KEY_ID=
TURN_KEY_API_TOKEN=

# Port for the local Deno server (default 44100).
PORT=44100
