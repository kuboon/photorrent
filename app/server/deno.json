{
  "tasks": {
    "check": "deno check; deno lint; deno test -P; deno fmt --check",
    "bundle": "deno task --cwd ../bundler build",
    "dev": "deno task bundle && deno serve -P --watch ./main.ts",
    "serve": "deno serve -P ./main.ts"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.unstable", "dom"],
    "jsx": "react-jsx",
    "jsxImportSource": "@remix-run/ui"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@kuboon/kv": "jsr:@kuboon/kv@0.1.1",
    "@kuboon/kv/memory.ts": "jsr:@kuboon/kv@0.1.1/memory.ts",
    "@kuboon/kv/denoKv.ts": "jsr:@kuboon/kv@0.1.1/denoKv.ts",
    "@remix-run/ui": "npm:@remix-run/ui@^0.1.1",
    "@remix-run/fetch-router": "npm:@remix-run/fetch-router@0.18.2",
    "@remix-run/response": "npm:@remix-run/response@0.3.3",
    "@remix-run/static-middleware": "npm:@remix-run/static-middleware@0.4.8"
  },
  "permissions": {
    "default": {
      "env": ["PORT"],
      "net": ["0.0.0.0", "localhost", "127.0.0.1"],
      "read": ["../bundled"]
    }
  }
}
